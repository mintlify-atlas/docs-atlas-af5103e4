  "keyFeatures": [
    "Room-based music streaming with host controls",
    "Democratic voting system for song queue ordering",
    "Real-time synchronization via WebSocket",
    "YouTube video integration",
    "Single room policy per user",
    "Google OAuth authentication"
  ],
  "publicApiSurface": [
    "POST /api/streams - Create a new room",
    "GET /api/streams/songs - Get room queue",
    "POST /api/streams/upvote - Upvote a song",
    "POST /api/streams/downVote - Downvote a song",
    "POST /api/streams/next - Skip to next song",
    "GET /api/streams/check-host - Check if user is host",
    "GET /api/streams/members - Get room member count",
    "POST /api/streams/leaveroom - Leave current room",
    "Socket: join-room - Join a room channel",
    "Socket: leave-room - Leave a room channel",
    "Socket: upvote - Broadcast upvote event",
    "Socket: downvote - Broadcast downvote event",
    "Socket: queue-update - Broadcast queue changes",
    "Socket: song-change - Broadcast song changes"
  ]
